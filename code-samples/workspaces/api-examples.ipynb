    "    \"    client_id=client_id,\\n\",\n",
    "    \"    redirect_url=redirect_url,\\n\",\n",
    "    \"    org_id=org_id,\\n\",\n",
    "    \"    hub_url=hub_url,\\n\",\n",
    "    \"    user_agent=client_name,\\n\",\n",
    "    \")\"\n",
    "   ]\n",
