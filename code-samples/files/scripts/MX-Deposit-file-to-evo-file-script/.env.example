# MX Deposit and Evo Workspace Configuration
# Copy this file to .env and fill in your credentials


# MX Deposit Configuration
# Required: Your MX Deposit project ID
MX_PROJECT_ID=<project_id>

# Required: Your MX Deposit template code
MX_TEMPLATE_CODE=<template_code>

# Required: Your MX Deposit API key
MX_API_KEY=<api_key>

# Required: Your MX Deposit client ID 
MX_CLIENT_ID=<client_id>



# Evo Configuration
# Required: Your Evo client ID (service account)
CLIENT_ID=<client_id>

# Required: Your Evo client secret
CLIENT_SECRET=<client_secret>

# Required: Evo Hub URL
HUB_URL=<hub_url>

# Required: Your Evo organization ID
ORG_ID=<org_id>

# Required: Your Evo workspace ID
WORKSPACE_ID=<workspace_id>
