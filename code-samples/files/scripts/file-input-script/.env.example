# Evo Workspace Configuration
# Copy this file to .env and fill in your credentials

# Required: Your Evo client ID (service account)
CLIENT_ID=<client-id>

# Required: Your Evo client secret
CLIENT_SECRET=<client-secret>

# Required: Evo Hub URL
HUB_URL=<hub-url>

# Required: Your Evo organization ID
ORG_ID=<org-id>

# Required: Your Evo workspace ID
WORKSPACE_ID=<workspace-id>

# Required: Path to the directory containing the files to be uploaded. Example: C:\Documents\drilling_data
DIR_PATH=<your-directory-path>